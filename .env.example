# Database Configuration
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
# Or use SQLite for local development:
# STAE_DB_URL=sqlite:///data/stae_acesso.db

# Security
STAE_SECRET_KEY=your-secret-key-here
STAE_DEBUG=false

# Server Configuration
STAE_HOST=0.0.0.0
STAE_PORT=5000

# Demo Accounts (optional)
STAE_DEMO_ADMIN_USER=admin
STAE_DEMO_ADMIN_PASSWORD=admin123
STAE_DEMO_POLICIA_USER=policia
STAE_DEMO_POLICIA_PASSWORD=policia123
STAE_DEMO_RH_USER=rh
STAE_DEMO_RH_PASSWORD=rh123

# Rate Limiting
STAE_LOGIN_MAX_ATTEMPTS=5
STAE_LOGIN_LOCKOUT_SECONDS=900
STAE_PER_PAGE=15
